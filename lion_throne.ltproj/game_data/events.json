    {
        "name": "Archive",
        "trigger": "Search",
        "level_nid": "SHUB",
        "condition": "True",
        "commands": [],
        "only_once": true,
        "priority": 20,
        "_source": [
            "transition;Close",
            "change_background;Study",
            "transition;Open",
            "add_portrait;Rowan;Left",
            "speak;Rowan;Ledgers. Flamekeeper ledgers, going back a century.",
            "speak;Rowan;Deaths in every shrine village, season after season. Someone kept count and said nothing.",
            "add_portrait;Iska;Right",
            "speak;Iska;Someone with very tidy handwriting. The man by the red-roofed house keeps looking over here.",
            "remove_portrait;Iska",
            "remove_portrait;Rowan",
            "give_item;{unit};EMB_CinderVial",
            "transition;Open",
            "add_talk;Rowan;Corwin",
            "has_attacked;{unit}"
        ],
        "nid": "SHUB Archive"
    },
    {
        "name": "TalkCorwin",
        "trigger": "on_talk",
        "level_nid": "SHUB",
        "condition": "unit2.nid == 'Corwin'",
        "commands": [],
        "only_once": true,
        "priority": 20,
        "_source": [
            "add_portrait;Corwin;Right",
            "add_portrait;Rowan;Left",
            "speak;Rowan;You kept the ledgers. You knew what the shrines were doing to us.",
            "speak;Corwin;I counted. Counting felt like scholarship. Silence felt like safety. It was neither.",
            "speak;Corwin;Take me with you. When you reach the reliquary, you will want someone who reads old valve schematics.",
            "speak;Rowan;Then stop counting and start speaking, archivist.",
            "change_team;Corwin;player",
            "give_item;Corwin;EMB_QuenchDraught",
            "game_var;corwin_joined;1",
            "remove_talk;Rowan;Corwin",
            "remove_portrait;Corwin",
            "remove_portrait;Rowan"
        ],
        "nid": "SHUB TalkCorwin"
    },
    {
        "name": "TalkKid",
        "trigger": "on_talk",
        "level_nid": "SHUB",
        "condition": "unit2.nid == 'Kid'",
        "commands": [],
        "only_once": true,
        "priority": 20,
        "_source": [
            "add_portrait;Boy2;Right",
            "speak;Boy2;Watch this! Halvard's old drill, one hundred swings before breakfast!",
            "speak;Boy2;You do it too! I bet you can't even keep up!",
            "remove_portrait;Boy2",
            "remove_talk;Rowan;Kid",
            "give_exp;{unit};20"
        ],
        "nid": "SHUB TalkKid"
    },
    {
        "name": "TalkVillager1",
        "trigger": "on_talk",
        "level_nid": "SHUB",
        "condition": "unit2.nid == 'Villager1'",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "add_portrait;Man1;Right",
            "speak;Man1;Stalls up the north road, forge across from them. The pit down southwest pays in bruises and javelins.",
            "speak;Man1;And if you want strange reading, the archivist keeps his door shut by the red-roofed house southeast.",
            "remove_portrait;Man1"
        ],
        "nid": "SHUB TalkVillager1"
    },
    {
        "name": "Depart",
