        "only_once": true,
        "priority": 20,
        "_source": [
            "transition;Close",
            "change_background;Arena",
            "transition;Open",
            "add_portrait;Jack;Right",
            "speak;Jack;The pit takes one challenger at a time. My champion, your best swing. Winner keeps the javelin.",
            "remove_portrait;Jack",
            "transition;Open",
            "add_unit;Duelist;6,10;immediate",
            "interact_unit;{unit};Duelist;hit1,hit1,end",
