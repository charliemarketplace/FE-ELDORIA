    {
        "name": "Intro",
        "trigger": "level_start",
        "level_nid": "S1",
        "condition": "True",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "show_layer;SickHouse",
            "transition;Close",
            "change_background;ClearingDark",
            "transition;Open",
            "add_portrait;Halvard;Left",
            "add_portrait;Rowan;Right",
            "speak;Halvard;Rowan. The coal is lit. Keep it low, keep it hidden.",
            "speak;Rowan;It's already glowing through my fingers. It knows something's coming.",
            "add_portrait;Iska;MidRight",
            "speak;Iska;Imperial banners on the ridge. Cinder Wardens. A lot of them.",
            "speak;Halvard;Take the coal and run if it turns bad. Promise me.",
            "speak;Rowan;You're scaring me, old man.",
            "speak;Halvard;Good. Fear keeps flamekeepers alive. Mostly.",
            "remove_portrait;Halvard",
            "remove_portrait;Iska",
            "remove_portrait;Rowan",
            "transition;Open"
        ],
        "nid": "S1 Intro"
    },
    {
        "name": "SickHouse",
        "trigger": "Visit",
        "level_nid": "S1",
        "condition": "True",
        "commands": [],
        "only_once": true,
        "priority": 20,
        "_source": [
            "transition;Close",
            "change_background;House",
            "transition;Open",
            "add_portrait;Woman2;Left",
            "speak;Woman2;My boy hasn't stopped coughing since the shrine flame flared last spring.",
            "speak;Woman2;The healers call it mountain air. I've stopped believing that.",
            "remove_portrait;Woman2",
            "transition;Open",
            "has_attacked;{unit}"
        ],
        "nid": "S1 SickHouse"
    },
    {
        "name": "FightDraven",
        "trigger": "combat_start",
        "level_nid": "S1",
        "condition": "check_default('Draven')",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "speak;Draven;The coal, girl. Emberhollow is already ash. Do not add yourself to it."
        ],
        "nid": "S1 FightDraven"
    },
    {
        "name": "WinGame",
        "trigger": "combat_end",
        "level_nid": "S1",
        "condition": "len(game.get_enemy_units()) == 0",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "add_portrait;Rowan;Left",
            "speak;Rowan;Draven's men are broken. Where's Halvard?",
            "add_portrait;Iska;Right",
            "speak;Iska;Rowan... I found his cloak by the shrine stone. Just the cloak.",
            "speak;Rowan;Then we carry the coal. For him.",
            "give_item;Rowan;EMB_EmberBlade",
            "give_money;400",
            "remove_portrait;Iska",
            "remove_portrait;Rowan",
            "transition;Close",
            "set_next_chapter;S2",
            "win_game"
        ],
        "nid": "S1 WinGame"
    },
