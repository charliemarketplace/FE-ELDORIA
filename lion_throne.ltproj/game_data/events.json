    {
        "name": "Intro",
        "trigger": "level_start",
        "level_nid": "S2",
        "condition": "True",
        "commands": [],
        "only_once": false,
        "priority": 20,
        "_source": [
            "add_talk;Iska;Tamsin",
            "transition;Close",
            "change_background;Desert",
            "transition;Open",
            "add_portrait;Rowan;Left",
            "speak;Rowan;Keep the line moving. Emberhold's a day off if we don't stop.",
            "add_portrait;Sable;MidLeft",
            "speak;Sable;Some of these folks haven't slept since Emberhollow burned.",
            "speak;Rowan;Neither have I. Doesn't matter right now.",
            "remove_portrait;Sable",
            "add_portrait;Iska;Right",
            "speak;Iska;Scouts on the ridge. Not soldiers. Cinder Wardens again.",
            "remove_portrait;Iska",
            "remove_portrait;Rowan",
            "transition;Open"
        ],
        "nid": "S2 Intro"
    },
    {
        "name": "ShrineRuin",
        "trigger": "Search",
        "level_nid": "S2",
        "condition": "True",
        "commands": [],
        "only_once": true,
        "priority": 20,
        "_source": [
            "transition;Close",
            "change_background;Ruins",
