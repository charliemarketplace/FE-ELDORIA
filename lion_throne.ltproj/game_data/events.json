            "add_portrait;Rowan;Left",
            "add_portrait;Iska;Right",
            "speak;Rowan;Every animal near this shrine stump is dead. Every one.",
            "speak;Iska;Ground's not scorched. Nothing burned them.",
            "remove_portrait;Rowan",
            "remove_portrait;Iska",
            "transition;Open",
            "game_var;met_ruin;1",
