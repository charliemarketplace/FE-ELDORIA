    <script type="application/javascript">

    globalThis.__canvas_resized = (self, ecw, ech) => {
        console.warn("TODO: panda3d canvas monitor", self, ecw, ech)
    }

    // --- Save persistence bridge (called from Python via platform.window) ---
    // Save files live in the tab's in-memory FS; these mirror them into
    // localStorage under "lt_save:<relpath>" so they survive reloads.

    function lt_saves_dump() {
        const data = {};
        for (let i = 0; i < localStorage.length; i++) {
            const k = localStorage.key(i);
            if (k && k.startsWith("lt_save:")) data[k.slice(8)] = localStorage.getItem(k);
        }
        return JSON.stringify(data);
    }

    function lt_saves_put_all(json_str) {
        try {
            const data = JSON.parse(json_str);
            const stale = [];
            for (let i = 0; i < localStorage.length; i++) {
                const k = localStorage.key(i);
                if (k && k.startsWith("lt_save:")) stale.push(k);
            }
            stale.forEach(k => localStorage.removeItem(k));
            for (const [k, v] of Object.entries(data)) localStorage.setItem("lt_save:" + k, v);
            return "ok";
        } catch (e) {
            return "error: " + e;
        }
    }

    function lt_export_saves() {
        const blob = new Blob([lt_saves_dump()], { type: "application/json" });
        const a = document.createElement("a");
        a.href = URL.createObjectURL(blob);
        a.download = "lion_throne_saves.json";
        a.click();
        URL.revokeObjectURL(a.href);
    }

    function lt_import_saves(file) {
        if (!file) return;
        const reader = new FileReader();
        reader.onload = () => {
            const res = lt_saves_put_all(reader.result);
            if (res === "ok") {
                alert("Saves imported. The page will reload to load them.");
                location.reload();
            } else {
                alert("Import failed: " + res);
            }
        };
        reader.readAsText(file);
    }

    function toggle_controls() {
        const card = document.getElementById("controls_card");
        card.style.display = (card.style.display === "none") ? "block" : "none";
    }

    function hide_controls() {
        document.getElementById("controls_card").style.display = "none";
    }

    // Dismiss the controls card on first interaction with the game
    document.addEventListener("keydown", hide_controls, { once: true });
    document.getElementById("canvas").addEventListener("mousedown", hide_controls, { once: true });

    // --- Mobile touch controls: translate taps into the same synthetic
    // keyboard events the engine already listens for (see app/engine/config.py
    // key_SELECT/BACK/INFO/AUX/START and driver.py's 1/2/5 speed hotkeys).
    // keydown fires on touch-start and keyup on touch-end/cancel so a held
    // button matches pygame.key.get_pressed()'s continuous state, same as a
    // held physical key (e.g. holding Cancel for fast cursor).
    const TC_KEYS = {
        up:    { code: "ArrowUp",    key: "ArrowUp",    keyCode: 38 },
        down:  { code: "ArrowDown",  key: "ArrowDown",  keyCode: 40 },
        left:  { code: "ArrowLeft",  key: "ArrowLeft",  keyCode: 37 },
        right: { code: "ArrowRight", key: "ArrowRight", keyCode: 39 },
        a:     { code: "Space",      key: " ",          keyCode: 32 },  // confirm
        b:     { code: "KeyA",       key: "a",          keyCode: 65 },  // cancel
        l:     { code: "KeyQ",       key: "q",          keyCode: 81 },  // cycle units
        r:     { code: "KeyW",       key: "w",          keyCode: 87 },  // unit info
        start: { code: "Tab",        key: "Tab",         keyCode: 9  },
        x1:    { code: "Digit1",     key: "1",          keyCode: 49 },
        x2:    { code: "Digit2",     key: "2",          keyCode: 50 },
        x5:    { code: "Digit5",     key: "5",          keyCode: 53 },
    };

    function tc_fire(type, desc) {
        const ev = new KeyboardEvent(type, { bubbles: true, cancelable: true, key: desc.key, code: desc.code });
        try {
            Object.defineProperty(ev, "keyCode", { get: () => desc.keyCode });
            Object.defineProperty(ev, "which", { get: () => desc.keyCode });
        } catch (e) { /* ignore on browsers that disallow redefining */ }
        const canvas = document.getElementById("canvas");
        if (canvas) canvas.dispatchEvent(ev);
        document.dispatchEvent(ev);
    }

    function tc_bind(el) {
        const desc = TC_KEYS[el.dataset.tc];
        if (!desc) return;
        const press = (e) => {
            e.preventDefault();
            try { el.setPointerCapture(e.pointerId); } catch (err) {}
            el.classList.add("tc_active");
            tc_fire("keydown", desc);
            if (el.classList.contains("tc_speed_btn")) {
                document.querySelectorAll("#tc_speed .tc_speed_btn").forEach(
                    (b) => b.classList.remove("tc_speed_current"));
                el.classList.add("tc_speed_current");
            }
        };
        const release = (e) => {
            el.classList.remove("tc_active");
            tc_fire("keyup", desc);
        };
        el.addEventListener("pointerdown", press);
        el.addEventListener("pointerup", release);
        el.addEventListener("pointercancel", release);
        el.addEventListener("pointerleave", release);
        el.addEventListener("contextmenu", (e) => e.preventDefault());
    }

    document.querySelectorAll("#touch_controls [data-tc]").forEach(tc_bind);

